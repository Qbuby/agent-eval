# ─────────────────────────────────────────────────────────────────────
# Agent Eval · 环境变量样板
# ─────────────────────────────────────────────────────────────────────
# 部署前把本文件复制成 .env，按需填写。已标 [必填] 的项不填启动会失败。
# Docker 部署：docker-compose.yml 通过 env_file: .env 一次性加载所有项。
# ─────────────────────────────────────────────────────────────────────

# ── LangSmith（agent 自身的 trace 落地地址；评估页跳转链接来源）──────
LANGSMITH_API_KEY=lsv2_pt_xxxxxxxx
LANGSMITH_PROJECT_NAME=my-project
# LANGSMITH_API_URL=https://api.smith.langchain.com
# LANGSMITH_DEFAULT_DATASET=

# ── Langfuse（评估工作台后端，可选；不填则关闭远程上报，仅本地存分）─
# 自建实例直接填 host；公有云一般是 https://cloud.langfuse.com。
# 三项任一为空时 settings.langfuse.configured=False，runner 不会推数据到 Langfuse。
LANGFUSE_HOST=https://langfuse.aidong-ai.com
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxx
# LANGFUSE_REMOTE_WRITE=false   # 默认 false；true 时 runner 会把每个 case 写到 Langfuse trace

# ── 内置 LLM（旧版 judge / scorer，仍被部分代码路径使用）────────────
# LLM_API_KEY=sk-xxxxxxxx
# LLM_MODEL=gpt-4o
# LLM_JUDGE_MODEL=gpt-4o
# LLM_BASE_URL=

# ── 数据库（compose 会强制覆盖 DB_HOST/DB_PORT；这里仅本机直跑用）──
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_NAME=agent_eval

# ── 用户认证（JWT 签名用）─────────────────────────────────────────
# [必填] 任意长度随机串，泄漏后等同于伪造任意用户。
AUTH_SECRET_KEY=your-secret-key-here-change-in-production
AUTH_ENABLED=true
# AUTH_ALGORITHM=HS256
# AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=30
# AUTH_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── 落库密钥加密（evaluator-provider API key 用）─────────────────────
# [必填] 用 Fernet 加密 evaluator_providers.api_key_encrypted（BYTEA）。
# 生成方式：
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Docker 部署也可以用：
#   docker run --rm python:3.11-slim sh -c "pip install -q cryptography && python -c \"from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())\""
# 注意：轮换此 key 会让所有已存的密文失效（需要在 UI 里重新粘贴 API key）。
SECURITY_FERNET_KEY=

# ── 镜像名 / tag（CI 编排用）──────────────────────────────────────────
# backend 与 migrate 共享同一镜像（migrate 不单独构建），杜绝「迁移代码 ≠
# 运行代码」的版本漂移。CI 产镜像后注入下列变量统一打 tag：
#   BACKEND_IMAGE  后端镜像全名（含 registry），如
#                  aidong-backend.tencentcloudcr.com/aidong/agent-eval
#   FRONTEND_IMAGE 前端镜像全名
#   IMAGE_TAG      统一 tag，如 main-25 / 提交短 SHA；本地默认 latest
# 本地 docker compose 不设这些变量时，默认 agent_eval-backend / -frontend:latest。
# BACKEND_IMAGE=aidong-backend.tencentcloudcr.com/aidong/agent-eval
# FRONTEND_IMAGE=aidong-backend.tencentcloudcr.com/aidong/agent-eval-frontend
# IMAGE_TAG=latest
